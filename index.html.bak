        { name: "转化路径设计", status: "off", date: "6.20-6.21" }
      ]
    },
    {
      id: "week2",
      label: "第2周",
      goal: "完成全站原型设计与 UI 视觉设计，输出高保真设计稿。",
      tasks: []
    },
    {
      id: "week3",
      label: "第3周",
      goal: "完成前端开发与后台管理系统建设。",
      tasks: []
    },
    {
      id: "week4",
