      goal: "完成内容填充、SEO/GEO 部署、测试验收与正式上线。",
      tasks: []
    }
  ],

  // 交付物（delivered: "on" 表示已交付，可配置 link）
  deliverables: [
    { title: "网站整体架构图", desc: "网站页面层级结构与导航体系设计", delivered: "off", expectedDate: "6.17", link: "" },
