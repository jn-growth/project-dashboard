      <span class="dot"></span>
      <span id="navPhase">需求梳理与网站策划</span>
    </div>
  </div>
</nav>

<!-- Main Content -->
<div class="main" id="mainContent">
  <!-- Overview -->
  <section class="overview fade-up">
    <div class="card overview-card">
      <div class="overview-header">
        <div>
          <h1 class="overview-title">捷牧教育官网建设项目</h1>
          <p class="overview-desc">建设捷牧教育官方网站，打造国际化、高端化品牌形象，提升用户咨询转化率，兼顾 SEO 搜索优化及 AI 搜索（GEO）优化需求。</p>
        </div>
        <span class="overview-status">进行中</span>
      </div>
      <div class="overview-meta">
        <div class="overview-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          当前阶段：<span id="metaPhase">需求梳理与网站策划</span>
        </div>
        <div class="overview-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          项目周期：2026-06-15 ~ 2026-07-15
        </div>
