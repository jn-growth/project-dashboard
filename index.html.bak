<!-- Generated by Trae Work -->
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>捷牧教育官网建设项目 - 项目进度</title>
  <style>
    /* === Reset & Base === */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      color: #0F172A; background: #F8FAFC; line-height: 1.6; overflow-x: hidden;
    }
    :root {
      --primary: #20516F; --primary-light: #2a6a8f; --primary-bg: rgba(32,81,111,0.08);
      --accent: #B01616; --bg: #F8FAFC; --card: #FFFFFF; --border: #E2E8F0;
      --border-light: #F1F5F9; --ink: #0F172A; --ink-secondary: #475569; --muted: #94A3B8;
      --success: #16A34A; --success-bg: rgba(22,163,74,0.08);
      --info: #3B82F6; --info-bg: rgba(59,130,246,0.08);
      --warning: #F59E0B; --warning-bg: rgba(245,158,11,0.08);
      --radius: 12px; --radius-sm: 8px;
      --shadow: 0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.03);
      --shadow-hover: 0 4px 12px rgba(0,0,0,0.07);
      --max-width: 1080px; --nav-height: 64px;
    }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--muted); border-radius: 3px; }

    /* === Password Overlay === */
    .auth-overlay {
      position: fixed; inset: 0; z-index: 9999;
      background: rgba(15,23,42,0.5); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      display: flex; align-items: center; justify-content: center;
      transition: opacity 0.5s ease, visibility 0.5s ease;
    }
    .auth-overlay.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
    .auth-overlay.hidden * { display: none; }
    .auth-card {
      background: var(--card); border-radius: 16px; padding: 40px;
      width: 380px; max-width: 90vw; text-align: center;
      box-shadow: 0 20px 60px rgba(0,0,0,0.12); animation: authCardIn 0.6s ease;
    }
    @keyframes authCardIn { from { opacity: 0; transform: translateY(20px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .auth-icon { width: 56px; height: 56px; border-radius: 16px; background: var(--primary-bg); display: inline-flex; align-items: center; justify-content: center; margin-bottom: 20px; }
    .auth-card h2 { font-size: 18px; font-weight: 600; margin-bottom: 6px; }
    .auth-card p { font-size: 13px; color: var(--muted); margin-bottom: 24px; }
    .auth-input { width: 100%; padding: 12px 16px; border: 1.5px solid var(--border); border-radius: var(--radius-sm); font-size: 15px; outline: none; transition: border-color 0.2s; background: var(--bg); font-family: inherit; }
    .auth-input:focus { border-color: var(--primary); }
    .auth-input.error { border-color: var(--accent); animation: shake 0.4s ease; }
    @keyframes shake { 0%,100%{transform:translateX(0)} 20%,60%{transform:translateX(-6px)} 40%,80%{transform:translateX(6px)} }
    .auth-error { color: var(--accent); font-size: 12px; margin-top: 8px; min-height: 18px; }
    .auth-btn { width: 100%; padding: 12px; background: var(--primary); color: #fff; border: none; border-radius: var(--radius-sm); font-size: 15px; font-weight: 500; cursor: pointer; margin-top: 12px; transition: background 0.2s, transform 0.1s; font-family: inherit; }
    .auth-btn:hover { background: var(--primary-light); }
    .auth-btn:active { transform: scale(0.98); }

    /* === Navigation === */
    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: var(--nav-height); display: flex; align-items: center; padding: 0 48px; transition: background 0.3s, box-shadow 0.3s; overflow: hidden; }
    .nav.scrolled { background: rgba(248,250,252,0.88); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); box-shadow: 0 1px 0 var(--border); }
    .nav-inner { max-width: var(--max-width); width: 100%; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
    .nav-brand { display: flex; align-items: center; gap: 12px; }
    .nav-logo { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden; }
    .nav-logo img { width: 100%; height: 100%; object-fit: contain; }
    .nav-title { font-size: 15px; font-weight: 600; color: var(--ink); }
    .nav-subtitle { font-size: 11px; color: var(--muted); margin-top: 1px; }
    .nav-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 500; background: var(--primary); color: #fff; }
    .nav-badge .dot { width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: pulse 2s ease infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

    /* === Gradient Animated Background === */
    .nav::before {
      content: ''; position: absolute; inset: 0; z-index: -1;
      background: linear-gradient(135deg, rgba(32,81,111,0.03) 0%, rgba(59,130,246,0.04) 50%, rgba(32,81,111,0.03) 100%);
      background-size: 200% 200%;
      animation: gradientShift 8s ease infinite;
    }
    @keyframes gradientShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .overview-card { position: relative; overflow: hidden; }
    .overview-card::before {
      content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
      background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(32,81,111,0.06) 0%, transparent 50%);
      pointer-events: none; z-index: 0;
    }
    .overview-card > * { position: relative; z-index: 1; }

    /* === 3D Tilt Card === */
    .tilt-card {
      transform-style: preserve-3d; perspective: 800px;
      transition: transform 0.15s ease-out, box-shadow 0.3s ease;
    }
    .tilt-card .tilt-shine {
      position: absolute; inset: 0; border-radius: var(--radius);
      background: radial-gradient(circle at var(--shine-x, 50%) var(--shine-y, 50%), rgba(255,255,255,0.15) 0%, transparent 60%);
      pointer-events: none; opacity: 0; transition: opacity 0.3s;
    }
    .tilt-card:hover .tilt-shine { opacity: 1; }

    /* === SVG Path Animation === */
    .timeline-line-animated {
      stroke-dasharray: 1000; stroke-dashoffset: 1000;
      animation: drawLine 1.5s ease forwards;
    }
    @keyframes drawLine {
      to { stroke-dashoffset: 0; }
    }
    .timeline-node-animated {
      opacity: 0; transform: scale(0);
      animation: nodePop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    @keyframes nodePop {
      to { opacity: 1; transform: scale(1); }
    }

    /* === Main Content === */
    .main { max-width: var(--max-width); margin: 0 auto; padding: calc(var(--nav-height) + 40px) 48px 60px; }
    .section-title { font-size: 18px; font-weight: 600; color: var(--ink); margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
    .section-title::before { content: ''; width: 3px; height: 18px; border-radius: 2px; background: var(--primary); flex-shrink: 0; }
    .card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow); transition: box-shadow 0.25s, transform 0.25s; }
    .card:hover { box-shadow: var(--shadow-hover); }

    /* === Overview === */
    .overview { margin-bottom: 32px; }
    .overview-card { padding: 28px; }
    .overview-header { display: flex; flex-wrap: wrap; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 20px; }
    .overview-title { font-size: 22px; font-weight: 700; color: var(--ink); letter-spacing: -0.02em; }
    .overview-status { display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 999px; font-size: 12px; font-weight: 500; background: var(--info-bg); color: var(--info); }
    .overview-desc { font-size: 14px; color: var(--ink-secondary); margin-bottom: 20px; max-width: 600px; line-height: 1.7; }
    .overview-meta { display: flex; flex-wrap: wrap; gap: 24px; margin-bottom: 24px; }
    .overview-meta-item { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--muted); }
    .overview-meta-item svg { width: 15px; height: 15px; opacity: 0.6; }
    .progress-wrap { display: flex; align-items: center; gap: 16px; }
    .progress-label { font-size: 13px; color: var(--ink-secondary); white-space: nowrap; }
    .progress-track { flex: 1; height: 8px; border-radius: 4px; background: var(--border-light); overflow: hidden; }
    .progress-fill { height: 100%; border-radius: 4px; background: var(--primary); transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1); width: 0; }
    .progress-value { font-size: 14px; font-weight: 600; color: var(--primary); min-width: 40px; text-align: right; }
    .time-info { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 20px; padding-top: 16px; border-top: 1px dashed var(--border); }
    .time-info-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--ink-secondary); }
    .time-info-item svg { width: 15px; height: 15px; color: var(--muted); opacity: 0.6; }
    .time-info-value { font-weight: 600; color: var(--primary); }
    .time-progress-mini { display: flex; align-items: center; gap: 8px; margin-left: auto; }
    .time-progress-mini-track { width: 80px; height: 4px; border-radius: 2px; background: var(--border-light); overflow: hidden; }
    .time-progress-mini-fill { height: 100%; border-radius: 2px; background: var(--info); transition: width 1s ease; }

    /* === Stats Grid === */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
    .stat-card { padding: 20px; }
    .stat-card-inner { display: flex; align-items: flex-start; justify-content: space-between; }
    .stat-label { font-size: 13px; color: var(--muted); margin-bottom: 6px; }
    .stat-value { font-size: 30px; font-weight: 700; color: var(--ink); letter-spacing: -0.03em; }
    .stat-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .stat-icon svg { width: 22px; height: 22px; }
    .stat-icon.green { background: var(--success-bg); color: var(--success); }
    .stat-icon.blue { background: var(--info-bg); color: var(--info); }
    .stat-icon.yellow { background: var(--warning-bg); color: var(--warning); }
    .stat-icon.primary { background: var(--primary-bg); color: var(--primary); }

    /* === Roadmap / Timeline === */
    .timeline { display: flex; flex-direction: column; }
    .timeline-item { display: flex; gap: 16px; position: relative; }
    .timeline-rail { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
    .timeline-node {
      width: 32px; height: 32px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; z-index: 1; border: 2px solid; transition: transform 0.2s;
    }
    .timeline-node:hover { transform: scale(1.1); }
    .timeline-node.completed { border-color: var(--success); background: var(--success-bg); }
    .timeline-node.completed svg { color: var(--success); }
    .timeline-node.active { border-color: var(--info); background: var(--info-bg); }
    .timeline-node.active svg { color: var(--info); animation: spin 2s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* === Mouse Hover Effects === */
    .card { transition: box-shadow 0.3s ease, transform 0.3s ease; }
    .card:hover { box-shadow: var(--shadow-hover); transform: translateY(-2px); }
    .stat-card { transition: box-shadow 0.3s ease, transform 0.3s ease; }
    .stat-card:hover { box-shadow: var(--shadow-hover); transform: translateY(-3px); }
    .stat-icon { transition: transform 0.3s ease; }
    .stat-card:hover .stat-icon { transform: scale(1.1) rotate(-3deg); }
    .deliverable-card { transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease; }
    .deliverable-card:hover { border-color: var(--primary); border-color: rgba(32,81,111,0.25); }
    .deliverable-link { transition: color 0.2s, gap 0.2s; }
    .deliverable-link:hover { gap: 6px; }
    .timeline-node { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .timeline-node:hover { transform: scale(1.15); box-shadow: 0 0 0 4px rgba(59,130,246,0.15); }
    .timeline-node.completed:hover { box-shadow: 0 0 0 4px rgba(22,163,74,0.15); }
    .timeline-node.pending:hover { box-shadow: 0 0 0 4px rgba(148,163,184,0.15); }
    .plan-task { transition: background 0.2s, padding-left 0.2s; }
    .plan-task:hover { background: var(--border-light); padding-left: 20px; }
    .phase-task { transition: background 0.2s, padding-left 0.2s; }
    .phase-task:hover { background: rgba(255,255,255,0.6); padding-left: 16px; }
    .plan-tab { transition: all 0.25s ease; }
    .nav-badge { transition: transform 0.2s, box-shadow 0.2s; }
    .nav-badge:hover { transform: scale(1.05); box-shadow: 0 2px 8px rgba(32,81,111,0.3); }
    .overview-title { transition: color 0.2s; }
    .section-title { transition: padding-left 0.3s ease; }
    .section-title:hover { padding-left: 4px; }
    .auth-btn { transition: background 0.2s, transform 0.15s, box-shadow 0.2s; }
    .auth-btn:hover { box-shadow: 0 4px 12px rgba(32,81,111,0.3); }
    .progress-fill { transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1); }
    .time-progress-mini-fill { transition: width 1s ease; }
    .timeline-node.pending { border-color: var(--border); background: var(--card); }
    .timeline-node.pending svg { color: var(--muted); }
    .timeline-node svg { width: 14px; height: 14px; }
    .timeline-line { width: 2px; flex: 1; min-height: 8px; }
    .timeline-line.completed { background: var(--success); }
    .timeline-line.active { background: var(--border); }
    .timeline-line.pending { background: var(--border); }
    .timeline-content { flex: 1; padding-bottom: 28px; }
    .timeline-header { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-bottom: 4px; }
    .timeline-name { font-size: 14px; font-weight: 600; color: var(--ink); }
    .timeline-badge { padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 500; }
    .timeline-badge.completed { background: var(--success-bg); color: var(--success); }
    .timeline-badge.active { background: var(--info-bg); color: var(--info); }
    .timeline-badge.pending { background: var(--border-light); color: var(--muted); }
    .timeline-date { font-size: 12px; color: var(--muted); margin-left: auto; }
    .timeline-desc { font-size: 13px; color: var(--ink-secondary); line-height: 1.6; margin-top: 2px; margin-bottom: 10px; }
    .timeline-item.active-item .timeline-content { background: var(--info-bg); border-radius: var(--radius-sm); padding: 12px 16px; margin: -4px -12px 24px; padding-bottom: 20px; }

    /* === Phase Task List (inside timeline) === */
    .phase-tasks { margin-top: 8px; }
    .phase-task {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 12px; border-radius: 6px; margin-bottom: 4px;
      transition: background 0.15s; font-size: 13px;
    }
    .phase-task:hover { background: rgba(255,255,255,0.5); }
    .phase-task-check {
      width: 18px; height: 18px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .phase-task-check.on { background: var(--success); }
    .phase-task-check.on svg { color: #fff; }
    .phase-task-check.off { border: 1.5px solid var(--border); }
    .phase-task-check svg { width: 11px; height: 11px; }
    .phase-task-name { flex: 1; }
    .phase-task-name.on { color: var(--muted); text-decoration: line-through; }
    .phase-task-name.off { color: var(--ink-secondary); }
    .phase-task-status { font-size: 11px; white-space: nowrap; }
    .phase-task-status.on { color: var(--success); }
    .phase-task-status.off { color: var(--muted); }
    .phase-task-date { font-size: 11px; color: var(--muted); margin-left: 4px; }
    .phase-summary {
      display: flex; align-items: center; gap: 8px; margin-top: 8px;
      font-size: 12px; color: var(--muted);
      padding-top: 8px; border-top: 1px dashed rgba(0,0,0,0.08);
    }
    .phase-summary-bar { flex: 1; height: 4px; border-radius: 2px; background: var(--border-light); overflow: hidden; }
    .phase-summary-fill { height: 100%; border-radius: 2px; background: var(--success); transition: width 0.6s ease; }

    /* === Plan Tabs === */
    .plan-tabs { display: flex; gap: 4px; padding: 4px; background: var(--border-light); border-radius: var(--radius-sm); margin-bottom: 20px; overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .plan-tab { padding: 8px 16px; border-radius: 6px; font-size: 13px; font-weight: 500; cursor: pointer; white-space: nowrap; border: none; background: transparent; color: var(--muted); transition: all 0.2s; font-family: inherit; }
    .plan-tab:hover { color: var(--ink-secondary); }
    .plan-tab.active { background: var(--card); color: var(--primary); box-shadow: var(--shadow); }
    .plan-panel { display: none; animation: fadeIn 0.3s ease; }
    .plan-panel.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
    .plan-goal { display: flex; gap: 12px; padding: 16px; background: var(--primary-bg); border-radius: var(--radius-sm); margin-bottom: 20px; align-items: flex-start; }
    .plan-goal svg { width: 18px; height: 18px; color: var(--primary); flex-shrink: 0; margin-top: 2px; }
    .plan-goal-label { font-size: 11px; color: var(--muted); margin-bottom: 2px; }
    .plan-goal-value { font-size: 13px; color: var(--ink); line-height: 1.6; }
    .plan-progress { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; padding: 12px 16px; border: 1px solid var(--border); border-radius: var(--radius-sm); }
    .plan-progress-left { display: flex; align-items: center; gap: 8px; }
    .plan-progress-label { font-size: 13px; color: var(--ink-secondary); }
    .plan-progress-value { font-size: 16px; font-weight: 700; color: var(--primary); }
    .plan-progress-count { font-size: 12px; color: var(--muted); }
    .plan-progress-bar { height: 6px; border-radius: 3px; background: var(--border-light); margin-bottom: 16px; overflow: hidden; }
    .plan-progress-fill { height: 100%; border-radius: 3px; background: var(--primary); transition: width 0.8s ease; }
    .plan-task { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border: 1px solid var(--border); border-radius: var(--radius-sm); margin-bottom: 8px; transition: background 0.15s; }
    .plan-task:hover { background: var(--border-light); }
    .plan-task-check { width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .plan-task-check.on { background: var(--success); }
    .plan-task-check.on svg { color: #fff; }
    .plan-task-check.off { border: 2px solid var(--border); }
    .plan-task-check svg { width: 12px; height: 12px; }
    .plan-task-name { font-size: 14px; flex: 1; }
    .plan-task-name.on { color: var(--muted); text-decoration: line-through; }
    .plan-task-name.off { color: var(--ink); }
    .plan-task-status { font-size: 12px; color: var(--muted); white-space: nowrap; }
    .plan-task-date { font-size: 11px; color: var(--muted); margin-left: 4px; }
    .plan-empty { text-align: center; padding: 40px 20px; color: var(--muted); }
    .plan-empty svg { width: 40px; height: 40px; margin-bottom: 12px; opacity: 0.3; }
    .plan-empty p { font-size: 14px; }

    /* === Deliverables === */
    .deliverables-section { margin-bottom: 40px; }
    .deliverables-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .deliverable-card { display: flex; gap: 16px; padding: 20px; }
    .deliverable-icon { width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0; background: var(--primary-bg); display: flex; align-items: center; justify-content: center; }
    .deliverable-icon svg { width: 20px; height: 20px; color: var(--primary); }
    .deliverable-icon.delivered { background: var(--success-bg); }
    .deliverable-icon.delivered svg { color: var(--success); }
    .deliverable-info { flex: 1; min-width: 0; }
    .deliverable-title { font-size: 15px; font-weight: 600; color: var(--ink); margin-bottom: 4px; }
    .deliverable-desc { font-size: 13px; color: var(--ink-secondary); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .deliverable-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; }
    .deliverable-date { font-size: 12px; color: var(--muted); display: flex; align-items: center; gap: 4px; }
    .deliverable-date svg { width: 13px; height: 13px; }
    .deliverable-status-badge { padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 500; }
    .deliverable-status-badge.delivered { background: var(--success-bg); color: var(--success); }
    .deliverable-status-badge.pending { background: var(--border-light); color: var(--muted); }
    .deliverable-link { font-size: 12px; font-weight: 500; color: var(--primary); text-decoration: none; display: flex; align-items: center; gap: 4px; transition: color 0.2s; }
    .deliverable-link:hover { color: var(--accent); }
    .deliverable-link svg { width: 13px; height: 13px; }

    /* === Footer === */
    .footer { max-width: var(--max-width); margin: 0 auto; padding: 0 48px 40px; }
    .footer-inner { border-top: 1px solid var(--border); padding-top: 24px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 12px; }
    .footer-left { font-size: 12px; color: var(--muted); }
    .footer-right { font-size: 12px; color: var(--muted); }

    /* === Scroll Animations === */
    .fade-up { opacity: 0; transform: translateY(16px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); margin-bottom: 32px;}

    /* === Responsive === */
    @media (max-width: 1024px) { .two-col { grid-template-columns: 1fr; } }
    @media (max-width: 768px) {
      .nav { padding: 0 16px; }
      .main { padding: calc(var(--nav-height) + 24px) 16px 40px; }
      .footer { padding: 0 16px 32px; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .deliverables-grid { grid-template-columns: 1fr; }
      .overview-title { font-size: 18px; }
      .overview-meta { gap: 12px; }
      .nav-subtitle { display: none; }
    }
    @media (max-width: 480px) {
      .stats-grid { gap: 10px; }
      .stat-card { padding: 16px; }
      .stat-value { font-size: 24px; }
      .plan-tab { padding: 6px 12px; font-size: 12px; }
    }
  </style>
</head>
<body>

<!-- Password Overlay -->
<div class="auth-overlay" id="authOverlay">
  <div class="auth-card">
    <div class="auth-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;color:var(--primary)">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>
    <h2>请输入查看密码</h2>
    <p>本页面仅限授权人员访问</p>
    <input type="password" class="auth-input" id="authInput" placeholder="输入密码" autocomplete="off">
    <div class="auth-error" id="authError"></div>
    <button class="auth-btn" id="authBtn">确认</button>
  </div>
</div>

<!-- Navigation -->
