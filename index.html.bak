    { title: "全站原型图", desc: "所有页面的交互原型设计", delivered: "off", expectedDate: "6.24", link: "" },
    { title: "UI 设计稿", desc: "全站高保真 UI 视觉设计稿", delivered: "off", expectedDate: "6.28", link: "" },
    { title: "品牌视觉规范", desc: "配色、字体、组件库等品牌设计标准", delivered: "off", expectedDate: "6.28", link: "" },
    { title: "前端开发包", desc: "前端页面代码与资源文件", delivered: "off", expectedDate: "7.3", link: "" },
    { title: "后台管理系统", desc: "CMS 内容管理后台系统", delivered: "off", expectedDate: "7.3", link: "" },
    { title: "测试报告", desc: "功能测试、兼容性测试、性能测试报告", delivered: "off", expectedDate: "7.10", link: "" },
    { title: "SEO/GEO 部署报告", desc: "搜索引擎优化与 AI 搜索优化部署情况", delivered: "off", expectedDate: "7.10", link: "" },
    { title: "上线验收报告", desc: "项目最终上线验收文档", delivered: "off", expectedDate: "7.15", link: "" }
  ]
};

// ============================================================
// 自动计算统计数据（根据任务实际状态）
// ============================================================
function calcStats() {
  // 从路线图阶段任务统计
  var allTasks = [];
  var activePhaseIdx = -1;
  for (var i = 0; i < PROJECT_DATA.phases.length; i++) {
    if (PROJECT_DATA.phases[i].status === "active") { activePhaseIdx = i; break; }
  }
  PROJECT_DATA.phases.forEach(function(phase, pi) {
    phase.tasks.forEach(function(task) {
      allTasks.push({ status: task.status, phaseIdx: pi });
    });
  });

  var total = allTasks.length;
  var done = allTasks.filter(function(t) { return t.status === "on"; }).length;
  var wip = 0;
  var todo = 0;
  allTasks.forEach(function(t) {
    if (t.status === "on") return;
    if (t.phaseIdx <= activePhaseIdx) { wip++; }
    else { todo++; }
  });

  var delivered = PROJECT_DATA.deliverables.filter(function(d) { return d.delivered === "on"; }).length;
  var progress = total > 0 ? Math.round((done / total) * 100) : 0;

  return { total: total, done: done, wip: wip, todo: todo, delivered: delivered, progress: progress };
}

// ============================================================
// 密码验证
// ============================================================
(function() {
  var overlay = document.getElementById('authOverlay');
  var input = document.getElementById('authInput');
  var btn = document.getElementById('authBtn');
  var error = document.getElementById('authError');
  if (sessionStorage.getItem('auth') === 'true') { overlay.classList.add('hidden'); initPage(); }
  function tryAuth() {
    if (input.value === VIEW_PASSWORD) {
      sessionStorage.setItem('auth', 'true');
      overlay.classList.add('hidden');
      initPage();
    } else {
      input.classList.add('error');
      error.textContent = '密码错误，请重新输入';
      setTimeout(function() { input.classList.remove('error'); }, 400);
    }
  }
  btn.addEventListener('click', tryAuth);
  input.addEventListener('keydown', function(e) { if (e.key === 'Enter') tryAuth(); });
  input.focus();
})();

// ============================================================
// 页面初始化
// ============================================================
function initPage() {
  updateStats();
  updateTimeInfo();
  renderTimeline();
  renderPlanTabs();
  renderDeliverables();
  animateProgress();
  setupScrollEffects();
}

// ============================================================
// 时间信息计算
// ============================================================
function updateTimeInfo() {
  var startDate = new Date(2026, 5, 15); // 月份从0开始，5=6月
  var endDate = new Date(2026, 6, 15);   // 6=7月
  var totalDays = Math.round((endDate - startDate) / (1000 * 60 * 60 * 24));
  var now = new Date();
  var elapsed = Math.round((now - startDate) / (1000 * 60 * 60 * 24));
  if (elapsed < 0) elapsed = 0;
  if (elapsed > totalDays) elapsed = totalDays;
  var remaining = totalDays - elapsed;
  var timePercent = Math.round((elapsed / totalDays) * 100);

  // 当前时间显示
  var y = now.getFullYear();
  var m = String(now.getMonth() + 1).padStart(2, '0');
  var d = String(now.getDate()).padStart(2, '0');
  var h = String(now.getHours()).padStart(2, '0');
  var min = String(now.getMinutes()).padStart(2, '0');
  document.getElementById('currentTime').textContent = y + '-' + m + '-' + d + ' ' + h + ':' + min;

  document.getElementById('daysElapsed').textContent = elapsed;
  document.getElementById('daysRemaining').textContent = remaining;
  document.getElementById('timeProgressValue').textContent = timePercent + '%';

  setTimeout(function() {
    document.getElementById('timeProgressFill').style.width = timePercent + '%';
  }, 400);
}

// ============================================================
// 更新概览区统计数据
// ============================================================
function updateStats() {
  var s = calcStats();
  document.getElementById('statDone').textContent = s.done;
  document.getElementById('statWip').textContent = s.wip;
  document.getElementById('statTodo').textContent = s.todo;
  document.getElementById('statDelivered').textContent = s.delivered;

  // 更新当前阶段名称
  var currentPhase = PROJECT_DATA.phases.filter(function(p) { return p.status === 'active'; })[0];
  if (currentPhase) {
    document.getElementById('navPhase').textContent = currentPhase.name;
    document.getElementById('metaPhase').textContent = currentPhase.name;
  }
}

// ============================================================
// 进度条动画
// ============================================================
function animateProgress() {
  var s = calcStats();
  setTimeout(function() {
    var fill = document.getElementById('progressFill');
    var value = document.getElementById('progressValue');
    fill.style.width = s.progress + '%';
    animateNumber(value, 0, s.progress, 1000);
  }, 300);
}

function animateNumber(el, from, to, duration) {
  var start = performance.now();
  function tick(now) {
    var elapsed = now - start;
    var p = Math.min(elapsed / duration, 1);
    var eased = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.round(from + (to - from) * eased) + '%';
    if (p < 1) requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
}

// ============================================================
// SVG 工具函数
// ============================================================
function svgCheck() { return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>'; }
function svgCircle() { return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg>'; }
function svgSpinner() { return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>'; }
function svgDot() { return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/></svg>'; }

// ============================================================
// 路线图渲染（含阶段内任务列表）
// ============================================================
function renderTimeline() {
  var container = document.getElementById('timeline');
  var html = '';
  var phases = PROJECT_DATA.phases;

  phases.forEach(function(phase, i) {
    var isLast = i === phases.length - 1;
    var isActive = phase.status === 'active';
    var isCompleted = phase.status === 'completed';
    var nodeClass = isCompleted ? 'completed' : isActive ? 'active' : 'pending';
    var badgeText = isCompleted ? '已完成' : isActive ? '进行中' : '未开始';
    var lineClass = isCompleted ? 'completed' : 'active';
    var itemClass = isActive ? 'timeline-item active-item' : 'timeline-item';

    var nodeSvg = isCompleted ? svgCheck() : isActive ? svgSpinner() : svgDot();

    html += '<div class="' + itemClass + '">';
    html += '  <div class="timeline-rail">';
    html += '    <div class="timeline-node ' + nodeClass + '">' + nodeSvg + '</div>';
    if (!isLast) html += '    <div class="timeline-line ' + lineClass + '"></div>';
    html += '  </div>';
    html += '  <div class="timeline-content">';
    html += '    <div class="timeline-header">';
    html += '      <span class="timeline-name">' + phase.name + '</span>';
    html += '      <span class="timeline-badge ' + nodeClass + '">' + badgeText + '</span>';
    html += '      <span class="timeline-date">' + phase.start + ' ~ ' + phase.end + '</span>';
    html += '    </div>';
    html += '    <div class="timeline-desc">' + phase.desc + '</div>';

    // 阶段内任务列表
    if (phase.tasks.length > 0) {
      var phaseDone = phase.tasks.filter(function(t) { return t.status === 'on'; }).length;
      var phaseTotal = phase.tasks.length;
      var phaseRate = phaseTotal > 0 ? Math.round((phaseDone / phaseTotal) * 100) : 0;

      html += '<div class="phase-tasks">';
      phase.tasks.forEach(function(task) {
        var isOn = task.status === 'on';
        html += '<div class="phase-task">';
        html += '  <div class="phase-task-check ' + (isOn ? 'on' : 'off') + '">' + (isOn ? svgCheck() : svgCircle()) + '</div>';
        html += '  <span class="phase-task-name ' + (isOn ? 'on' : 'off') + '">' + task.name + '</span>';
        html += '  <span class="phase-task-date">' + task.date + '</span>';
        html += '  <span class="phase-task-status ' + (isOn ? 'on' : 'off') + '">' + (isOn ? '已完成' : '未完成') + '</span>';
        html += '</div>';
      });
      html += '</div>';

      // 阶段完成进度摘要
      html += '<div class="phase-summary">';
      html += '  <span>' + phaseDone + '/' + phaseTotal + '</span>';
      html += '  <div class="phase-summary-bar"><div class="phase-summary-fill" style="width:' + phaseRate + '%"></div></div>';
      html += '  <span>' + phaseRate + '%</span>';
      html += '</div>';
    }

    html += '  </div>';
    html += '</div>';
  });

  container.innerHTML = html;
}

// ============================================================
// 计划选项卡渲染
// ============================================================
function renderPlanTabs() {
  var tabsContainer = document.getElementById('planTabs');
  var panelsContainer = document.getElementById('planPanels');
  var plans = PROJECT_DATA.plans;
  var tabsHtml = '';
  var panelsHtml = '';

  plans.forEach(function(plan, i) {
    var activeClass = i === 0 ? ' active' : '';
    tabsHtml += '<button class="plan-tab' + activeClass + '" data-tab="' + plan.id + '">' + plan.label + '</button>';
    panelsHtml += '<div class="plan-panel' + activeClass + '" id="panel-' + plan.id + '">' + renderPlanPanel(plan) + '</div>';
  });

  tabsContainer.innerHTML = tabsHtml;
  panelsContainer.innerHTML = panelsHtml;

  tabsContainer.addEventListener('click', function(e) {
    var tab = e.target.closest('.plan-tab');
    if (!tab) return;
    var tabId = tab.dataset.tab;
    document.querySelectorAll('.plan-tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.plan-panel').forEach(function(p) { p.classList.remove('active'); });
    tab.classList.add('active');
    document.getElementById('panel-' + tabId).classList.add('active');
  });
}

function renderPlanPanel(plan) {
  var html = '';
  if (plan.goal) {
    html += '<div class="plan-goal">';
    html += '  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>';
    html += '  <div><div class="plan-goal-label">目标</div><div class="plan-goal-value">' + plan.goal + '</div></div>';
    html += '</div>';
  }
  if (plan.tasks.length === 0) {
    html += '<div class="plan-empty"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg><p>暂无计划，待更新</p></div>';
    return html;
  }

  plan.tasks.forEach(function(task) {
    var isOn = task.status === 'on';
    html += '<div class="plan-task">';
    html += '  <div class="plan-task-check ' + (isOn ? 'on' : 'off') + '">' + (isOn ? svgCheck() : svgCircle()) + '</div>';
    html += '  <span class="plan-task-name ' + (isOn ? 'on' : 'off') + '">' + task.name + '</span>';
    html += '</div>';
  });
  return html;
}

// ============================================================
// 交付物渲染
// ============================================================
function renderDeliverables() {
  var container = document.getElementById('deliverablesGrid');
  var html = '';

  PROJECT_DATA.deliverables.forEach(function(item) {
    var isDelivered = item.delivered === 'on';
    var iconClass = isDelivered ? 'deliverable-icon delivered' : 'deliverable-icon';
    var iconSvg = isDelivered
      ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
      : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>';

    var statusBadge = isDelivered
      ? '<span class="deliverable-status-badge delivered">已交付</span>'
      : '<span class="deliverable-status-badge pending">待交付</span>';

    var dateHtml = '';
    if (isDelivered) {
      dateHtml = '<span class="deliverable-date"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>已交付</span>';
    } else {
      dateHtml = '<span class="deliverable-date"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>预计 ' + item.expectedDate + '</span>';
    }

    html += '<div class="card deliverable-card">';
    html += '  <div class="' + iconClass + '">' + iconSvg + '</div>';
    html += '  <div class="deliverable-info">';
    html += '    <div class="deliverable-title">' + item.title + '</div>';
    html += '    <div class="deliverable-desc">' + item.desc + '</div>';
    html += '    <div class="deliverable-footer">';
    html +=      dateHtml;
    html +=      statusBadge;
    if (isDelivered && item.link) {
      html += '      <a class="deliverable-link" href="' + item.link + '" target="_blank" rel="noopener">查看 <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a>';
    }
    html += '    </div>';
    html += '  </div>';
    html += '</div>';
  });

  container.innerHTML = html;
}

// ============================================================
// 滚动效果
// ============================================================
function setupScrollEffects() {
  var nav = document.getElementById('nav');
  window.addEventListener('scroll', function() {
    if (window.scrollY > 60) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  });
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.fade-up').forEach(function(el) { observer.observe(el); });

  // === 3D Tilt + Magnetic Cursor ===
  setupTiltCards();
  setupMagneticCursor();
  setupSVGPathAnimation();
}

// ============================================================
// 3D Tilt Cards
// ============================================================
function setupTiltCards() {
  var cards = document.querySelectorAll('.stat-card, .deliverable-card');
  cards.forEach(function(card) {
    card.classList.add('tilt-card');
    // Add shine overlay
    var shine = document.createElement('div');
    shine.className = 'tilt-shine';
    card.style.position = 'relative';
    card.appendChild(shine);

    card.addEventListener('mousemove', function(e) {
      var rect = card.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;
      var centerX = rect.width / 2;
      var centerY = rect.height / 2;
      var rotateX = ((y - centerY) / centerY) * -6;
      var rotateY = ((x - centerX) / centerX) * 6;
      card.style.transform = 'perspective(800px) rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg) translateY(-2px)';
      card.style.setProperty('--shine-x', (x / rect.width * 100) + '%');
      card.style.setProperty('--shine-y', (y / rect.height * 100) + '%');
    });

    card.addEventListener('mouseleave', function() {
      card.style.transform = 'perspective(800px) rotateX(0) rotateY(0) translateY(0)';
    });
  });
}

// ============================================================
// Magnetic Cursor on Overview Card
// ============================================================
function setupMagneticCursor() {
  var overviewCard = document.querySelector('.overview-card');
  if (!overviewCard) return;
  overviewCard.addEventListener('mousemove', function(e) {
    var rect = overviewCard.getBoundingClientRect();
    var x = ((e.clientX - rect.left) / rect.width) * 100;
    var y = ((e.clientY - rect.top) / rect.height) * 100;
    overviewCard.style.setProperty('--mouse-x', x + '%');
    overviewCard.style.setProperty('--mouse-y', y + '%');
  });
}

// ============================================================
// SVG Path Animation for Timeline Lines
// ============================================================
function setupSVGPathAnimation() {
  // Replace timeline lines with SVG animated lines
  var lines = document.querySelectorAll('.timeline-line');
  lines.forEach(function(line, i) {
    line.classList.add('timeline-line-animated');
    line.style.animationDelay = (i * 0.3) + 's';
  });

  // Animate timeline nodes with stagger
  var nodes = document.querySelectorAll('.timeline-node');
  nodes.forEach(function(node, i) {
    node.classList.add('timeline-node-animated');
    node.style.animationDelay = (i * 0.2 + 0.3) + 's';
  });
}
</script>
</body>
</html>
